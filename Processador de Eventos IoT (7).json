    {
      "parameters": {
        "jsCode": "// timeline já agrupada e ordenada\nconst deviceData = $item(0).$node[\"Processar Dispositivo Individualmente\"].json;\nconst previousState = items[0]?.json || null;\n\n// 🔹 Estado inicial vindo do banco\nlet destravado = false;\nlet aberto = false;\n\n// Se existir estado anterior\nif (previousState && previousState.device_id) {\n  aberto = !previousState.is_closed;\n  destravado = !previousState.is_locked;\n}\n\n// Flags\nlet invasionDetected = false;\n\n// 🔎 Vamos controlar quando houve destravamento\nlet lastUnlockTimestamp = null;\n\nfor (const event of deviceData.timeline) {\n\n  // Se destravou\n  if (event.alarm_id === 33 && event.value === 1) {\n    destravado = true;\n    lastUnlockTimestamp = new Date(event.timestamp);\n  }\n\n  if (event.alarm_id === 33 && event.value === 0) {\n    destravado = false;\n  }\n\n  // Se abriu\n  if (event.alarm_id === 32 && event.value === 1) {\n\n    const openTimestamp = new Date(event.timestamp);\n\n    // 🚨 Invasão só se abrir SEM ter destravado antes\n    if (!lastUnlockTimestamp || lastUnlockTimestamp > openTimestamp) {\n      invasionDetected = true;\n    }\n\n    aberto = true;\n  }\n\n  if (event.alarm_id === 32 && event.value === 0) {\n    aberto = false;\n  }\n}\n\nconst estado_final = { aberto, destravado };\n\n// 📌 Vulnerabilidade conforme PDF:\n// fechado (32 = 0) e destravado (33 = 1)\nconst vulnerabilityDetected =\n  estado_final.aberto === false &&\n  estado_final.destravado === true;\n\nreturn [{\n  json: {\n    device_id: deviceData.device_id,\n    timeline: deviceData.timeline,\n    estado_final,\n    flags: {\n      invasionDetected,\n      vulnerabilityDetected\n    }\n  }\n}];"
      },
