        "jsCode": "const raw = $json.output[0].content[0].text;\n\nconst cleaned = raw\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst parsed = JSON.parse(cleaned);\n\n// pegar dados consolidados do node anterior\nconst deviceData = $item(0).$node[\"Processar Dispositivo Individualmente\"].json;\n\nreturn [{\n  json: {\n    device_id: deviceData.device_id,\n    event_ids: deviceData.timeline.map(e => e.id),\n    estado_final: deviceData.estado_final,\n    ...parsed\n  }\n}];"
