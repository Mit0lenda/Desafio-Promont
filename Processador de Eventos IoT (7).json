      "parameters": {
        "jsCode": "const events = items.map(item => item.json);\n\n// 1️⃣ Agrupar por device\nconst grouped = {};\n\nfor (const event of events) {\n  if (!grouped[event.device_id]) {\n    grouped[event.device_id] = [];\n  }\n  grouped[event.device_id].push(event);\n}\n\n// 2️⃣ Ordenar por timestamp\nfor (const deviceId in grouped) {\n  grouped[deviceId].sort((a, b) => {\n    return new Date(a.timestamp) - new Date(b.timestamp);\n  });\n}\n\nconst output = [];\n\n// 3️⃣ Reconstrução de estado\nfor (const deviceId in grouped) {\n\n  const timeline = grouped[deviceId];\n\n  let destravado = false;\n  let aberto = false;\n  let invasionDetected = false;\n\n  for (const event of timeline) {\n\n    if (event.alarm_id === 33) {\n      destravado = event.value === 1;\n    }\n\n    if (event.alarm_id === 32) {\n\n      if (event.value === 1 && destravado === false) {\n        invasionDetected = true;\n      }\n\n      aberto = event.value === 1;\n    }\n  }\n\n  const estado_final = { aberto, destravado };\n\n  const vulnerabilityDetected =\n    estado_final.aberto === false &&\n    estado_final.destravado === true;\n\n  output.push({\n    json: {\n      device_id: deviceId,\n      timeline,\n      estado_final,\n      flags: {\n        invasionDetected,\n        vulnerabilityDetected\n      }\n    }\n  });\n}\n\nreturn output;"
      },
